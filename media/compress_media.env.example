# =============================================================================
# compress_media.env.example
# Copia questo file in compress_media.env e adattalo al tuo server.
# Il file .env NON va committato su git (aggiungilo a .gitignore).
# =============================================================================

# ── PERCORSI ─────────────────────────────────────────────────────────────────
# Cartella sorgente (dove sono le foto/video originali)
SOURCE="/home/nextcloud-data/data/data/arma/files/Toshiba"

# Cartella destinazione (dove salvare i file compressi)
DEST="/mnt/nextcloud_hdd/Foto-compresse"

# File di log
LOG_FILE="/home/arma/compress_media.log"

# ── QUALITÀ VIDEO ─────────────────────────────────────────────────────────────
# CRF per H.265: 24 = alta qualità, 28 = bilanciato, 30 = più compresso
VIDEO_CRF=28

# Preset ffmpeg: slow (migliore compressione) | medium | fast (più veloce)
VIDEO_PRESET="slow"

# ── QUALITÀ FOTO ──────────────────────────────────────────────────────────────
# -q:v per JPEG: 2 = alta qualità, 4 = bilanciato, 6 = più compresso
JPEG_QUALITY=4

# ── OPZIONI CONVERSIONE ───────────────────────────────────────────────────────
# Converti HEIC → JPG (true/false)
CONVERT_HEIC=true

# Converti PNG → JPG (false di default: i PNG potrebbero essere grafica/loghi)
CONVERT_PNG=false

# Comprimi video MP4/MOV → H.265 (true/false)
COMPRESS_VIDEO=true

# ── CARTELLE DA ESCLUDERE ─────────────────────────────────────────────────────
# Array di nomi di cartelle da ignorare (es. loghi, grafica, RAW)
# Sintassi bash array — NON usare virgolette attorno all'array intero
EXCLUDE_DIRS=("Arma Logo" "Files")
